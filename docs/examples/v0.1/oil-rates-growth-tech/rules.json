{
  "spec_version": "v0.1",
  "description": "User-provided seed rules before compiler refinement.",
  "rules": [
    {
      "rule_id": "seed_reduce_growth_tech_oil_rates",
      "name": "Seed rule: reduce growth tech when oil and rates rise",
      "layer": "strategy",
      "priority": 65,
      "confidence": 0.65,
      "when": {
        "all": [
          {
            "signal": "wti_change_20d",
            "operator": ">",
            "value": 0.1,
            "unit": "percent"
          },
          {
            "signal": "ust10y_change_20d",
            "operator": ">",
            "value": 25,
            "unit": "basis_points"
          }
        ]
      },
      "then": [
        {
          "action": "decrease_weight",
          "target": "QQQ",
          "amount": 0.05,
          "unit": "weight",
          "reason": "Oil and long rates are rising together."
        },
        {
          "action": "increase_weight",
          "target": "cash",
          "amount": 0.05,
          "unit": "weight",
          "reason": "Raise cash during macro pressure."
        }
      ]
    },
    {
      "rule_id": "rotate_growth_to_defensive_when_oil_rates_pressure_active",
      "name": "Rotate growth technology to defensive equities when oil/rates pressure is active",
      "layer": "cross_asset_relations",
      "priority": 72,
      "confidence": 0.7,
      "when": {
        "all": [
          {
            "signal": "wti_change_20d",
            "operator": ">",
            "value": 0.1,
            "unit": "percent"
          },
          {
            "signal": "ust10y_change_20d",
            "operator": ">",
            "value": 25,
            "unit": "basis_points"
          }
        ]
      },
      "then": [
        {
          "action": "rotate",
          "from": "growth_technology",
          "to": "defensive_equities",
          "target": "portfolio",
          "target_type": "portfolio",
          "amount": 0.1,
          "unit": "weight",
          "reason": "Rotate from rate-sensitive growth technology into defensive equities."
        }
      ]
    }
  ]
}
