{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphanet.dev/specs/v0.1/regime.schema.json",
  "title": "AlphaNet Regime Schema",
  "description": "Schema for AlphaNet v0.1 regime definitions. Regimes summarize market environments inferred from signals, relations, portfolio state, or other regimes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "regime_id",
    "conditions"
  ],
  "properties": {
    "regime_id": {
      "$ref": "#/$defs/id",
      "description": "Unique regime identifier."
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "$ref": "#/$defs/regime_category"
    },
    "state_mode": {
      "type": "string",
      "enum": [
        "active_inactive",
        "scored",
        "probabilistic"
      ],
      "default": "active_inactive",
      "description": "How this regime is evaluated by the backtester."
    },
    "conditions": {
      "$ref": "#/$defs/condition",
      "description": "Conditions that determine whether or how strongly the regime is active."
    },
    "confidence": {
      "$ref": "#/$defs/confidence",
      "description": "Default confidence in this regime definition."
    },
    "activation_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "For scored/probabilistic regimes, score required to mark active."
    },
    "lookback": {
      "$ref": "#/$defs/window",
      "description": "Optional default lookback window for regime evaluation."
    },
    "persistence": {
      "$ref": "#/$defs/persistence",
      "description": "Optional persistence/smoothing behavior."
    },
    "implications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/implication"
      },
      "description": "Expected market implications when this regime is active."
    },
    "priority": {
      "$ref": "#/$defs/priority",
      "description": "Optional priority among regimes if multiple regimes conflict."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "signal_interests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal_interest"
      },
      "default": []
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "window": {
      "type": "string",
      "pattern": "^[0-9]+[dwmqy]$",
      "description": "Window such as 20d, 3m, 1y."
    },
    "regime_category": {
      "type": "string",
      "enum": [
        "risk",
        "liquidity",
        "inflation",
        "growth",
        "rates",
        "credit",
        "volatility",
        "valuation",
        "sentiment",
        "global_macro",
        "real_economy",
        "market_flow",
        "custom"
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        ">",
        ">=",
        "<",
        "<=",
        "==",
        "!=",
        "between",
        "in",
        "not_in",
        "active",
        "inactive",
        "exists",
        "missing",
        "crosses_above",
        "crosses_below"
      ]
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/condition"
            }
          }
        },
        {
          "required": [
            "score"
          ],
          "properties": {
            "score": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/scored_condition"
              },
              "minItems": 1
            },
            "threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "method": {
              "type": "string",
              "enum": [
                "weighted_average",
                "sum",
                "majority",
                "custom"
              ],
              "default": "weighted_average"
            }
          }
        },
        {
          "required": [
            "signal",
            "operator"
          ],
          "properties": {
            "signal": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "unit": {
              "type": "string"
            },
            "lookback": {
              "$ref": "#/$defs/window"
            }
          }
        },
        {
          "required": [
            "relation",
            "operator"
          ],
          "properties": {
            "relation": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "confidence_min": {
              "$ref": "#/$defs/confidence"
            }
          }
        },
        {
          "required": [
            "regime",
            "operator"
          ],
          "properties": {
            "regime": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "confidence_min": {
              "$ref": "#/$defs/confidence"
            }
          }
        },
        {
          "required": [
            "portfolio_metric",
            "operator"
          ],
          "properties": {
            "portfolio_metric": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "target": {
              "type": "string"
            }
          }
        }
      ]
    },
    "scored_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition",
        "weight"
      ],
      "properties": {
        "condition": {
          "$ref": "#/$defs/condition"
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "positive_score": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "default": 1
        },
        "negative_score": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "default": 0
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_active_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum days regime remains active after triggering."
        },
        "confirmation_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of days condition must persist before activation."
        },
        "cooldown_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of days before regime can re-trigger."
        },
        "smoothing": {
          "type": "string",
          "enum": [
            "none",
            "moving_average",
            "exponential",
            "custom"
          ],
          "default": "none"
        }
      }
    },
    "implication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "effect"
      ],
      "properties": {
        "target": {
          "type": "string",
          "description": "Symbol, sector, asset class, theme, relation, or portfolio exposure affected by this regime."
        },
        "target_type": {
          "type": "string",
          "enum": [
            "symbol",
            "asset_class",
            "sector",
            "theme",
            "factor",
            "relation",
            "portfolio",
            "custom"
          ]
        },
        "effect": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral",
            "mixed",
            "risk_on",
            "risk_off",
            "increase_volatility",
            "decrease_volatility",
            "increase_cash",
            "reduce_exposure",
            "custom"
          ]
        },
        "strength": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "type": "string"
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "expires_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "category_key": {
          "type": "string"
        },
        "supersedes_policy": {
          "type": "string",
          "enum": [
            "latest_effective_date_wins",
            "none"
          ]
        },
        "source_report_ref": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "signal_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "series_id": {
          "type": "string"
        },
        "adapter": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        }
      }
    },
    "transform_spec": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "window": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "data_requirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "frequency": {
          "type": "string"
        },
        "lookback": {
          "type": "string"
        },
        "price_adjustment": {
          "type": "string"
        },
        "requires_ohlcv": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string"
        },
        "rating": {
          "type": "string"
        },
        "direction": {
          "type": "string"
        },
        "entry_price": {
          "type": "number"
        },
        "target_price": {
          "type": "number"
        },
        "stop_loss": {
          "type": "number"
        },
        "time_horizon": {
          "type": "string"
        },
        "horizon_days": {
          "type": "integer"
        },
        "position_sizing": {
          "type": "string"
        },
        "allocation_pct": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "signal_interest_condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "right": {
          "type": "string"
        },
        "value": {},
        "unit": {
          "type": "string"
        }
      }
    },
    "signal_interest_threshold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "value": {},
        "unit": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        }
      }
    },
    "signal_interest_interpretation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interpretation_id": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/signal_interest_condition"
        },
        "meaning": {
          "type": "string"
        },
        "recommendation_bias": {
          "type": "string"
        },
        "action_bias": {
          "type": "string"
        },
        "applies_to": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_text": {
          "type": "string"
        },
        "thresholds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal_interest_threshold"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "signal_interest_resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        },
        "data_provider": {
          "type": "string"
        },
        "backtester_supported": {
          "type": "boolean"
        },
        "requires_ohlcv": {
          "type": "boolean"
        },
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "agent_report_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "format",
        "path"
      ],
      "properties": {
        "engine": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "format": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "family"
      ],
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "signal_kind": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/signal_source"
            }
          ]
        },
        "instrument": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "transform": {
          "type": "string"
        },
        "transform_spec": {
          "$ref": "#/$defs/transform_spec"
        },
        "window": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "value": {},
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "recommendation": {
          "$ref": "#/$defs/recommendation"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "data_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_requirement"
          }
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_price": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "value_range": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "signal_interest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "family"
      ],
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/signal_source"
            }
          ]
        },
        "instrument": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "transform": {
          "type": "string"
        },
        "transform_spec": {
          "$ref": "#/$defs/transform_spec"
        },
        "window": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "data_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_requirement"
          }
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_price": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "value_range": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "reason": {
          "type": "string"
        },
        "extracted_from": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/signal_interest_resolution"
        },
        "thresholds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal_interest_threshold"
          }
        },
        "interpretations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal_interest_interpretation"
          }
        }
      }
    }
  },
  "examples": [
    {
      "regime_id": "tight_liquidity",
      "name": "Tight Liquidity",
      "description": "Restrictive liquidity regime characterized by elevated rates, strong dollar pressure, and/or credit tightening.",
      "category": "liquidity",
      "state_mode": "active_inactive",
      "conditions": {
        "all": [
          {
            "signal": "fed_funds_rate",
            "operator": ">",
            "value": 3.5,
            "unit": "percent"
          },
          {
            "any": [
              {
                "signal": "dxy_change_60d",
                "operator": ">",
                "value": 0.03,
                "unit": "percent"
              },
              {
                "signal": "bank_tightening_sloos",
                "operator": ">",
                "value": 5.0,
                "unit": "percent"
              }
            ]
          }
        ]
      },
      "confidence": 0.81,
      "activation_threshold": 0.65,
      "persistence": {
        "confirmation_days": 2,
        "min_active_days": 5,
        "smoothing": "none"
      },
      "implications": [
        {
          "target": "equities",
          "target_type": "asset_class",
          "effect": "risk_off",
          "strength": -0.6,
          "confidence": 0.75
        },
        {
          "target": "cash",
          "target_type": "asset_class",
          "effect": "increase_cash",
          "strength": 0.5,
          "confidence": 0.7
        }
      ],
      "priority": 80
    },
    {
      "regime_id": "inflationary_pressure",
      "name": "Inflationary Pressure",
      "category": "inflation",
      "state_mode": "scored",
      "conditions": {
        "score": [
          {
            "condition": {
              "signal": "cpi_yoy",
              "operator": ">",
              "value": 3.0,
              "unit": "percent"
            },
            "weight": 0.5
          },
          {
            "condition": {
              "signal": "wti_change_20d",
              "operator": ">",
              "value": 0.1,
              "unit": "percent"
            },
            "weight": 0.3
          },
          {
            "condition": {
              "signal": "ust10y_breakeven_change_20d",
              "operator": ">",
              "value": 10,
              "unit": "basis_points"
            },
            "weight": 0.2
          }
        ],
        "threshold": 0.6,
        "method": "weighted_average"
      },
      "confidence": 0.72,
      "activation_threshold": 0.6,
      "implications": [
        {
          "target": "long_duration_equities",
          "target_type": "theme",
          "effect": "negative",
          "strength": -0.5,
          "confidence": 0.7
        },
        {
          "target": "commodities",
          "target_type": "asset_class",
          "effect": "positive",
          "strength": 0.4,
          "confidence": 0.65
        }
      ]
    }
  ]
}
