{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphanet.dev/specs/v0.1/portfolio.schema.json",
  "title": "AlphaNet Portfolio Schema",
  "description": "Schema for AlphaNet v0.1 portfolio configuration, allocation targets, constraints, rebalancing policy, and risk budgets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "base_currency",
    "starting_cash"
  ],
  "properties": {
    "base_currency": {
      "type": "string",
      "default": "USD",
      "description": "Base currency used for portfolio accounting."
    },
    "starting_cash": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 100000,
      "description": "Initial portfolio capital."
    },
    "initial_allocation": {
      "$ref": "#/$defs/initial_allocation"
    },
    "candidate_baskets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate_basket"
      },
      "description": "Baskets of candidate securities the portfolio may buy or rotate into later."
    },
    "selection_policy": {
      "$ref": "#/$defs/selection_policy"
    },
    "targets": {
      "type": "object",
      "description": "Hard or preferred allocation targets by asset class, symbol, sector, theme, or exposure bucket. Values are weights from 0 to 1.",
      "additionalProperties": {
        "$ref": "#/$defs/weight"
      }
    },
    "soft_targets": {
      "type": "array",
      "description": "Allocation targets with tolerance bands.",
      "items": {
        "$ref": "#/$defs/soft_target"
      }
    },
    "constraints": {
      "$ref": "#/$defs/constraints"
    },
    "risk_budgets": {
      "$ref": "#/$defs/risk_budgets"
    },
    "rebalance": {
      "$ref": "#/$defs/rebalance_policy"
    },
    "execution_overrides": {
      "$ref": "#/$defs/execution_overrides"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Free-form implementation metadata."
    }
  },
  "$defs": {
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signed_weight": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "non_negative_number": {
      "type": "number",
      "minimum": 0
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "asset_class",
        "symbol",
        "sector",
        "theme",
        "factor",
        "exposure",
        "custom"
      ]
    },
    "asset_class": {
      "type": "string",
      "enum": [
        "cash",
        "equities",
        "bonds",
        "commodities",
        "crypto",
        "real_assets",
        "alternatives",
        "currency",
        "rates",
        "volatility",
        "custom"
      ]
    },
    "soft_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "weight",
        "tolerance"
      ],
      "properties": {
        "target": {
          "type": "string",
          "description": "Target bucket, e.g. equities, cash, QQQ, technology."
        },
        "target_kind": {
          "$ref": "#/$defs/target_kind"
        },
        "weight": {
          "$ref": "#/$defs/weight"
        },
        "tolerance": {
          "$ref": "#/$defs/weight",
          "description": "Allowed absolute drift around target weight."
        },
        "min": {
          "$ref": "#/$defs/weight",
          "description": "Optional explicit minimum allowed weight."
        },
        "max": {
          "$ref": "#/$defs/weight",
          "description": "Optional explicit maximum allowed weight."
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Priority used if soft targets conflict."
        },
        "rebalance_when_breached": {
          "type": "boolean",
          "default": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Hard portfolio constraints. These should not be violated by the portfolio engine.",
      "properties": {
        "cash_min": {
          "$ref": "#/$defs/weight"
        },
        "cash_max": {
          "$ref": "#/$defs/weight"
        },
        "max_single_position": {
          "$ref": "#/$defs/weight"
        },
        "min_single_position": {
          "$ref": "#/$defs/weight"
        },
        "max_positions": {
          "type": "integer",
          "minimum": 1
        },
        "min_positions": {
          "type": "integer",
          "minimum": 1
        },
        "max_asset_class_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          },
          "description": "Maximum weight by asset class."
        },
        "min_asset_class_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          },
          "description": "Minimum weight by asset class."
        },
        "max_sector_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "min_sector_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "max_theme_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "max_factor_exposure": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/signed_weight"
          },
          "description": "Maximum signed exposure by factor."
        },
        "min_factor_exposure": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/signed_weight"
          },
          "description": "Minimum signed exposure by factor."
        },
        "max_leverage": {
          "type": "number",
          "minimum": 0,
          "default": 1
        },
        "allow_shorting": {
          "type": "boolean",
          "default": false
        },
        "allow_margin": {
          "type": "boolean",
          "default": false
        },
        "allowed_assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "Optional explicit allowlist of tradable assets."
        },
        "blocked_assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "Optional explicit blocklist of assets."
        },
        "allowed_asset_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_class"
          },
          "uniqueItems": true
        },
        "blocked_asset_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_class"
          },
          "uniqueItems": true
        }
      }
    },
    "risk_budgets": {
      "type": "object",
      "additionalProperties": false,
      "description": "Risk limits and portfolio-level controls.",
      "properties": {
        "max_portfolio_volatility": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum annualized portfolio volatility."
        },
        "target_portfolio_volatility": {
          "type": "number",
          "minimum": 0,
          "description": "Optional target annualized portfolio volatility."
        },
        "max_drawdown": {
          "$ref": "#/$defs/weight"
        },
        "max_beta": {
          "type": "number"
        },
        "min_beta": {
          "type": "number"
        },
        "max_daily_turnover": {
          "$ref": "#/$defs/weight"
        },
        "max_monthly_turnover": {
          "$ref": "#/$defs/weight"
        },
        "max_trade_weight": {
          "$ref": "#/$defs/weight"
        },
        "max_trade_notional": {
          "$ref": "#/$defs/non_negative_number"
        },
        "max_daily_loss": {
          "$ref": "#/$defs/weight"
        },
        "max_var": {
          "$ref": "#/$defs/weight",
          "description": "Maximum Value-at-Risk as portfolio fraction."
        },
        "max_cvar": {
          "$ref": "#/$defs/weight",
          "description": "Maximum Conditional Value-at-Risk as portfolio fraction."
        },
        "de_risking_policy": {
          "$ref": "#/$defs/de_risking_policy"
        }
      }
    },
    "de_risking_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional rules for reducing risk after a risk budget breach.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "trigger": {
          "type": "string",
          "enum": [
            "drawdown",
            "volatility",
            "daily_loss",
            "var",
            "custom"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "raise_cash",
            "reduce_equities",
            "reduce_risk",
            "rebalance_to_targets",
            "block_new_positions",
            "custom"
          ]
        },
        "amount": {
          "$ref": "#/$defs/weight"
        },
        "cooldown_days": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rebalance_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Portfolio rebalancing policy.",
      "properties": {
        "frequency": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "event_driven"
          ],
          "default": "daily"
        },
        "threshold": {
          "$ref": "#/$defs/weight",
          "description": "Rebalance when drift exceeds this absolute weight."
        },
        "allow_partial_rebalance": {
          "type": "boolean",
          "default": true
        },
        "min_trade_weight": {
          "$ref": "#/$defs/weight",
          "description": "Ignore trades smaller than this portfolio weight."
        },
        "max_rebalance_turnover": {
          "$ref": "#/$defs/weight"
        },
        "calendar": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "day_of_week": {
              "type": "string",
              "enum": [
                "monday",
                "tuesday",
                "wednesday",
                "thursday",
                "friday"
              ]
            },
            "day_of_month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            }
          }
        }
      }
    },
    "execution_overrides": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional execution-level overrides defined by the portfolio.",
      "properties": {
        "block_trades_when_cash_below_min": {
          "type": "boolean",
          "default": true
        },
        "scale_orders_to_fit_constraints": {
          "type": "boolean",
          "default": true
        },
        "prefer_cash_buffer": {
          "type": "boolean",
          "default": true
        },
        "rounding": {
          "type": "string",
          "enum": [
            "none",
            "nearest_share",
            "floor_shares"
          ],
          "default": "none"
        }
      }
    },
    "initial_allocation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Defines the portfolio holdings at the start of the backtest or runtime simulation.",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "cash",
            "weights",
            "dollars",
            "shares"
          ],
          "description": "How initial positions are specified."
        },
        "positions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/initial_position"
          },
          "description": "Initial cash and/or security positions."
        },
        "on_missing_prices": {
          "type": "string",
          "enum": [
            "fail",
            "skip",
            "cash_substitute"
          ],
          "default": "fail"
        },
        "rebalance_on_start": {
          "type": "boolean",
          "default": false,
          "description": "If true, immediately rebalance from the initial allocation toward portfolio targets on the first tradable date."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "cash"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "positions": {
                "default": [
                  {
                    "symbol": "cash",
                    "weight": 1.0
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "enum": [
                  "weights",
                  "dollars",
                  "shares"
                ]
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "positions"
            ]
          }
        }
      ]
    },
    "initial_position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Tradable symbol or cash."
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "Dollar amount when mode is dollars, or cash amount when symbol is cash."
        },
        "shares": {
          "type": "number",
          "minimum": 0
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "oneOf": [
        {
          "required": [
            "weight"
          ]
        },
        {
          "required": [
            "amount"
          ]
        },
        {
          "required": [
            "shares"
          ]
        }
      ]
    },
    "candidate_basket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basket_id",
        "symbols"
      ],
      "properties": {
        "basket_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._:-]+$",
          "description": "Unique basket identifier that rules may target."
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "asset_class": {
          "type": "string"
        },
        "sector": {
          "type": "string"
        },
        "sectors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "theme": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "risk_asset",
            "defensive_asset",
            "hedge",
            "cash_proxy",
            "duration",
            "commodity",
            "custom"
          ]
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "min_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_position_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_position_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Defines how the portfolio engine selects securities inside candidate baskets.",
      "properties": {
        "default_method": {
          "type": "string",
          "enum": [
            "equal_weight",
            "ranked",
            "score_weighted",
            "market_cap_weighted",
            "manual",
            "custom"
          ],
          "default": "ranked"
        },
        "rebalance_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_holding_days": {
          "type": "integer",
          "minimum": 0
        },
        "baskets": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/basket_selection_policy"
          }
        }
      }
    },
    "basket_selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "equal_weight",
            "ranked",
            "score_weighted",
            "market_cap_weighted",
            "manual",
            "custom"
          ]
        },
        "max_positions": {
          "type": "integer",
          "minimum": 1
        },
        "min_position_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_position_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ranking": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ranking_signal"
          }
        },
        "replacement_policy": {
          "$ref": "#/$defs/replacement_policy"
        }
      }
    },
    "ranking_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "weight"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "direction": {
          "type": "string",
          "enum": [
            "higher_is_better",
            "lower_is_better"
          ]
        }
      }
    },
    "replacement_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "rebalance_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_holding_days": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "examples": [
    {
      "base_currency": "USD",
      "starting_cash": 100000,
      "targets": {
        "cash": 0.25,
        "equities": 0.5,
        "bonds": 0.2,
        "commodities": 0.05
      },
      "soft_targets": [
        {
          "target": "equities",
          "target_kind": "asset_class",
          "weight": 0.5,
          "tolerance": 0.1,
          "priority": 60
        }
      ],
      "constraints": {
        "cash_min": 0.1,
        "max_single_position": 0.15,
        "max_asset_class_weight": {
          "equities": 0.65,
          "bonds": 0.5,
          "commodities": 0.25
        },
        "max_sector_weight": {
          "technology": 0.35
        },
        "max_leverage": 1.0,
        "allow_shorting": false,
        "allow_margin": false
      },
      "risk_budgets": {
        "max_portfolio_volatility": 0.2,
        "max_drawdown": 0.15,
        "max_daily_turnover": 0.1,
        "max_trade_weight": 0.05,
        "de_risking_policy": {
          "enabled": true,
          "trigger": "drawdown",
          "action": "raise_cash",
          "amount": 0.1,
          "cooldown_days": 10
        }
      },
      "rebalance": {
        "frequency": "daily",
        "threshold": 0.05,
        "allow_partial_rebalance": true,
        "min_trade_weight": 0.005
      },
      "initial_allocation": {
        "mode": "weights",
        "positions": [
          {
            "symbol": "SPY",
            "weight": 0.4
          },
          {
            "symbol": "QQQ",
            "weight": 0.25
          },
          {
            "symbol": "TLT",
            "weight": 0.2
          },
          {
            "symbol": "cash",
            "weight": 0.15
          }
        ]
      },
      "candidate_baskets": [
        {
          "basket_id": "growth_technology",
          "description": "Growth technology and AI-related equities the strategy may buy or sell.",
          "asset_class": "equities",
          "sector": "technology",
          "role": "risk_asset",
          "symbols": [
            "QQQ",
            "NVDA",
            "AMD",
            "MSFT",
            "AAPL",
            "AVGO",
            "SMH"
          ],
          "max_weight": 0.35,
          "min_position_weight": 0.02,
          "max_position_weight": 0.1
        },
        {
          "basket_id": "defensive_equities",
          "description": "Defensive equity alternatives.",
          "asset_class": "equities",
          "sectors": [
            "utilities",
            "consumer_staples",
            "healthcare"
          ],
          "role": "defensive_asset",
          "symbols": [
            "XLU",
            "XLP",
            "XLV",
            "JNJ",
            "PG",
            "KO"
          ],
          "max_weight": 0.3
        },
        {
          "basket_id": "duration",
          "description": "Treasury duration instruments.",
          "asset_class": "bonds",
          "role": "duration",
          "symbols": [
            "SHY",
            "IEF",
            "TLT"
          ],
          "max_weight": 0.5
        },
        {
          "basket_id": "commodities_energy",
          "description": "Energy and oil-related instruments.",
          "asset_class": "commodities",
          "sector": "energy",
          "role": "commodity",
          "symbols": [
            "USO",
            "XLE",
            "XOM",
            "CVX"
          ],
          "max_weight": 0.25
        }
      ],
      "selection_policy": {
        "default_method": "ranked",
        "rebalance_threshold": 0.05,
        "min_holding_days": 10,
        "baskets": {
          "growth_technology": {
            "method": "ranked",
            "max_positions": 5,
            "min_position_weight": 0.02,
            "max_position_weight": 0.1,
            "ranking": [
              {
                "signal": "relative_strength_60d",
                "weight": 0.4,
                "direction": "higher_is_better"
              },
              {
                "signal": "news_sentiment_7d",
                "weight": 0.3,
                "direction": "higher_is_better"
              },
              {
                "signal": "realized_volatility_20d",
                "weight": 0.3,
                "direction": "lower_is_better"
              }
            ],
            "replacement_policy": {
              "enabled": true,
              "rebalance_threshold": 0.15,
              "min_holding_days": 10
            }
          }
        }
      }
    }
  ]
}
