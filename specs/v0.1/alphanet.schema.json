{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphanet.dev/specs/v0.1/alphanet.schema.json",
  "title": "AlphaNet Intermediate Representation",
  "description": "Top-level schema for AlphaNet v0.1 compiled strategy.ir.json files. This is the deterministic AIR artifact consumed by the backtester.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "universe",
    "signals",
    "portfolio",
    "decision_hierarchy",
    "rules",
    "execution"
  ],
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "universe": {
      "$ref": "#/$defs/universe"
    },
    "signals": {
      "type": "array",
      "description": "Signal definitions available to regimes, relations, and rules.",
      "items": {
        "$ref": "#/$defs/signal"
      },
      "uniqueItems": false
    },
    "relations": {
      "type": "array",
      "description": "Cross-asset or cross-domain relation definitions.",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    },
    "regimes": {
      "type": "array",
      "description": "Regime definitions inferred from signals, relations, or portfolio state.",
      "items": {
        "$ref": "#/$defs/regime"
      },
      "default": []
    },
    "portfolio": {
      "$ref": "#/$defs/portfolio"
    },
    "decision_hierarchy": {
      "$ref": "#/$defs/decision_hierarchy"
    },
    "rules": {
      "type": "array",
      "description": "Rules evaluated by the backtester.",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "execution": {
      "$ref": "#/$defs/execution",
      "properties": {
        "benchmarks": {
          "$ref": "#/$defs/benchmarks_config"
        }
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Reserved extension object for future AlphaNet versions or private tooling."
    },
    "benchmarks": {
      "$ref": "#/$defs/benchmarks_config"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signed_weight": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_name",
        "spec_version",
        "generated_at"
      ],
      "properties": {
        "strategy_name": {
          "type": "string",
          "minLength": 1
        },
        "strategy_id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "Strategy version."
        },
        "spec_version": {
          "type": "string",
          "const": "v0.1"
        },
        "compiler_version": {
          "type": "string"
        },
        "generated_at": {
          "$ref": "#/$defs/date_time"
        },
        "source_hash": {
          "type": "string",
          "description": "Optional hash of source strategy files."
        },
        "ir_hash": {
          "type": "string",
          "description": "Optional SHA-256 hash of canonicalized AIR."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "universe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assets"
      ],
      "properties": {
        "assets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "asset_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_class"
          },
          "uniqueItems": true
        },
        "sectors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "themes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/theme"
          }
        },
        "benchmark": {
          "type": "string",
          "description": "Optional benchmark symbol, e.g. SPY."
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "asset_class"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "name": {
          "type": "string"
        },
        "asset_class": {
          "$ref": "#/$defs/asset_class"
        },
        "sector": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "exchange": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "tradable": {
          "type": "boolean",
          "default": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "asset_class": {
      "type": "string",
      "enum": [
        "cash",
        "equities",
        "bonds",
        "commodities",
        "crypto",
        "real_assets",
        "alternatives",
        "currency",
        "rates",
        "volatility",
        "custom"
      ]
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "theme_id",
        "members"
      ],
      "properties": {
        "theme_id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "family"
      ],
      "properties": {
        "signal_id": {
          "$ref": "#/$defs/id"
        },
        "family": {
          "type": "string",
          "enum": [
            "valuation",
            "macro",
            "global_macro",
            "fed",
            "shipping",
            "market_flow",
            "events",
            "sentiment",
            "volatility",
            "portfolio",
            "custom"
          ]
        },
        "type": {
          "type": "string",
          "description": "Signal type, e.g. level, percent_change, rate_change, z_score, ranking, sentiment_score."
        },
        "source": {
          "type": "string",
          "description": "Data source identifier."
        },
        "instrument": {
          "type": "string",
          "description": "Instrument, economic series, or source symbol referenced by this signal."
        },
        "symbol": {
          "type": "string",
          "description": "Primary asset symbol if applicable."
        },
        "field": {
          "type": "string",
          "description": "Input field, e.g. close, yield, volume, cpi_yoy."
        },
        "transform": {
          "type": "string",
          "enum": [
            "level",
            "change",
            "percent_change",
            "difference",
            "ratio",
            "spread",
            "moving_average",
            "z_score",
            "rank",
            "correlation",
            "volatility",
            "sentiment_score",
            "event_count",
            "custom"
          ]
        },
        "window": {
          "type": "string",
          "pattern": "^[0-9]+[dwmqy]$",
          "description": "Window such as 20d, 3m, 1y."
        },
        "unit": {
          "type": "string",
          "description": "Unit such as percent, basis_points, dollars, vessels, tons."
        },
        "value_range": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id",
        "drivers",
        "targets",
        "effect"
      ],
      "properties": {
        "relation_id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        },
        "drivers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Signal, regime, or relation ids that drive this relation."
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Symbols, asset classes, sectors, themes, or regimes affected by the relation."
        },
        "effect": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral",
            "mixed",
            "risk_on",
            "risk_off",
            "increase_volatility",
            "decrease_volatility"
          ]
        },
        "conditions": {
          "$ref": "#/$defs/condition"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "strength": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "window": {
          "type": "string",
          "pattern": "^[0-9]+[dwmqy]$"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regime_id",
        "conditions"
      ],
      "properties": {
        "regime_id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "conditions": {
          "$ref": "#/$defs/condition"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "state_mode": {
          "type": "string",
          "enum": [
            "active_inactive",
            "scored",
            "probabilistic"
          ],
          "default": "active_inactive"
        },
        "implications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/regime_implication"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "regime_implication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "effect"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "effect": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "portfolio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_currency",
        "starting_cash"
      ],
      "properties": {
        "base_currency": {
          "type": "string",
          "default": "USD"
        },
        "starting_cash": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 100000
        },
        "initial_allocation": {
          "$ref": "#/$defs/initial_allocation"
        },
        "candidate_baskets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate_basket"
          }
        },
        "selection_policy": {
          "$ref": "#/$defs/selection_policy"
        },
        "targets": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          },
          "description": "Target weights by asset class, symbol, sector, theme, or exposure bucket."
        },
        "soft_targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/soft_target"
          }
        },
        "constraints": {
          "$ref": "#/$defs/portfolio_constraints"
        },
        "risk_budgets": {
          "$ref": "#/$defs/risk_budgets"
        },
        "rebalance": {
          "$ref": "#/$defs/rebalance_policy"
        }
      }
    },
    "soft_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "weight",
        "tolerance"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "weight": {
          "$ref": "#/$defs/weight"
        },
        "tolerance": {
          "$ref": "#/$defs/weight"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "portfolio_constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cash_min": {
          "$ref": "#/$defs/weight"
        },
        "cash_max": {
          "$ref": "#/$defs/weight"
        },
        "max_single_position": {
          "$ref": "#/$defs/weight"
        },
        "max_asset_class_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "min_asset_class_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "max_sector_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "max_theme_weight": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/weight"
          }
        },
        "max_leverage": {
          "type": "number",
          "minimum": 0,
          "default": 1
        },
        "allow_shorting": {
          "type": "boolean",
          "default": false
        },
        "allow_margin": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "risk_budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_portfolio_volatility": {
          "type": "number",
          "minimum": 0
        },
        "max_drawdown": {
          "$ref": "#/$defs/weight"
        },
        "max_beta": {
          "type": "number"
        },
        "max_daily_turnover": {
          "$ref": "#/$defs/weight"
        },
        "max_trade_weight": {
          "$ref": "#/$defs/weight"
        }
      }
    },
    "rebalance_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "event_driven"
          ],
          "default": "daily"
        },
        "threshold": {
          "$ref": "#/$defs/weight"
        },
        "allow_partial_rebalance": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "decision_hierarchy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layers"
      ],
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decision_layer"
          }
        },
        "conflict_resolution": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "layer_priority",
              "rule_priority",
              "confidence",
              "tie_breaker"
            ]
          },
          "default": [
            "layer_priority",
            "rule_priority",
            "confidence",
            "tie_breaker"
          ]
        },
        "tie_breaker": {
          "type": "string",
          "enum": [
            "rule_order",
            "lexicographic_rule_id",
            "most_conservative",
            "explicit"
          ],
          "default": "rule_order"
        }
      }
    },
    "decision_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "priority"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "portfolio_safety",
            "risk_management",
            "regime",
            "cross_asset_relations",
            "strategy",
            "tactical",
            "experimental",
            "custom"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "description": {
          "type": "string"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "layer",
        "priority",
        "when",
        "then"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "layer": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "when": {
          "$ref": "#/$defs/condition"
        },
        "then": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          },
          "minItems": 1
        },
        "valid_from": {
          "$ref": "#/$defs/date"
        },
        "valid_to": {
          "$ref": "#/$defs/date"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/condition"
            }
          }
        },
        {
          "required": [
            "signal",
            "operator"
          ],
          "properties": {
            "signal": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "unit": {
              "type": "string"
            }
          }
        },
        {
          "required": [
            "regime",
            "operator"
          ],
          "properties": {
            "regime": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {}
          }
        },
        {
          "required": [
            "relation",
            "operator"
          ],
          "properties": {
            "relation": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {}
          }
        },
        {
          "required": [
            "portfolio_metric",
            "operator"
          ],
          "properties": {
            "portfolio_metric": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {}
          }
        },
        {
          "required": [
            "event",
            "operator"
          ],
          "properties": {
            "event": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {}
          }
        }
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        ">",
        ">=",
        "<",
        "<=",
        "==",
        "!=",
        "between",
        "in",
        "not_in",
        "active",
        "inactive",
        "exists",
        "missing"
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "target"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "increase_weight",
            "decrease_weight",
            "set_weight",
            "buy",
            "sell",
            "hold",
            "rebalance",
            "raise_cash",
            "reduce_risk",
            "block_trade",
            "rotate",
            "allocate_to_basket",
            "reduce_basket",
            "rank_and_select",
            "replace_low_ranked"
          ]
        },
        "target": {
          "type": "string",
          "description": "Symbol, basket id, asset class, sector, theme, exposure bucket, cash, or portfolio."
        },
        "amount": {
          "type": "number",
          "description": "Action amount. Interpretation depends on action_type."
        },
        "unit": {
          "type": "string",
          "enum": [
            "weight",
            "shares",
            "dollars",
            "percent",
            "risk_fraction",
            "custom"
          ],
          "default": "weight"
        },
        "reason": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "target_type": {
          "type": "string",
          "enum": [
            "symbol",
            "basket",
            "asset_class",
            "sector",
            "theme",
            "factor",
            "portfolio",
            "cash",
            "custom"
          ],
          "description": "Disambiguates the target namespace for basket and portfolio-level actions."
        },
        "from": {
          "type": "string",
          "description": "Source target for rotate actions."
        },
        "to": {
          "type": "string",
          "description": "Destination target for rotate actions."
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rebalance_frequency": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "event_driven"
          ],
          "default": "daily"
        },
        "order_timing": {
          "type": "string",
          "enum": [
            "same_close",
            "next_open",
            "next_close"
          ],
          "default": "next_open"
        },
        "transaction_cost_bps": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
