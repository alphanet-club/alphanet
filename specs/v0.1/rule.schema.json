{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphanet.dev/specs/v0.1/rule.schema.json",
  "title": "AlphaNet Rule Schema",
  "description": "Schema for AlphaNet v0.1 rules. Rules consume signals, regimes, relations, events, dates, and portfolio state, then emit requested actions. Conflict resolution is handled through layer priority, rule priority, confidence, and deterministic tie breakers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "layer",
    "priority",
    "when",
    "then"
  ],
  "properties": {
    "rule_id": {
      "$ref": "#/$defs/id",
      "description": "Unique rule identifier."
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "layer": {
      "$ref": "#/$defs/layer"
    },
    "priority": {
      "$ref": "#/$defs/priority",
      "description": "Priority within the rule's layer. Layer priority is evaluated before individual rule priority."
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "when": {
      "$ref": "#/$defs/condition"
    },
    "then": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "minItems": 1
    },
    "else": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "description": "Optional actions when the condition does not match."
    },
    "valid_from": {
      "type": "string",
      "format": "date"
    },
    "valid_to": {
      "type": "string",
      "format": "date"
    },
    "cooldown": {
      "$ref": "#/$defs/cooldown"
    },
    "limits": {
      "$ref": "#/$defs/rule_limits"
    },
    "explain": {
      "$ref": "#/$defs/explanation"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "signal_interests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal_interest"
      },
      "default": []
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "portfolio_safety",
        "risk_management",
        "regime",
        "cross_asset_relations",
        "strategy",
        "tactical",
        "experimental",
        "custom"
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        ">",
        ">=",
        "<",
        "<=",
        "==",
        "!=",
        "between",
        "in",
        "not_in",
        "active",
        "inactive",
        "exists",
        "missing",
        "crosses_above",
        "crosses_below"
      ]
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/condition"
              },
              "minItems": 1
            }
          }
        },
        {
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/condition"
            }
          }
        },
        {
          "required": [
            "signal",
            "operator"
          ],
          "properties": {
            "signal": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "unit": {
              "type": "string"
            },
            "lookback": {
              "$ref": "#/$defs/window"
            }
          }
        },
        {
          "required": [
            "regime",
            "operator"
          ],
          "properties": {
            "regime": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "confidence_min": {
              "$ref": "#/$defs/confidence"
            }
          }
        },
        {
          "required": [
            "relation",
            "operator"
          ],
          "properties": {
            "relation": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "confidence_min": {
              "$ref": "#/$defs/confidence"
            }
          }
        },
        {
          "required": [
            "portfolio_metric",
            "operator"
          ],
          "properties": {
            "portfolio_metric": {
              "type": "string"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "target": {
              "type": "string",
              "description": "Optional asset, asset class, sector, or theme for the metric."
            },
            "unit": {
              "type": "string"
            }
          }
        },
        {
          "required": [
            "event",
            "operator"
          ],
          "properties": {
            "event": {
              "$ref": "#/$defs/id"
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {},
            "symbol": {
              "type": "string"
            },
            "window": {
              "$ref": "#/$defs/window"
            }
          }
        },
        {
          "required": [
            "date",
            "operator"
          ],
          "properties": {
            "date": {
              "type": "string",
              "enum": [
                "current_date",
                "month",
                "quarter",
                "day_of_week",
                "days_since_start",
                "custom"
              ]
            },
            "operator": {
              "$ref": "#/$defs/operator"
            },
            "value": {}
          }
        }
      ]
    },
    "window": {
      "type": "string",
      "pattern": "^[0-9]+[dwmqy]$",
      "description": "Window such as 5d, 20d, 3m, 1y."
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "$ref": "#/$defs/action_type"
        },
        "target": {
          "type": "string",
          "description": "Symbol, basket id, asset class, sector, theme, exposure bucket, cash, or portfolio. Required for target-based actions."
        },
        "amount": {
          "type": "number",
          "description": "Action amount. Interpretation depends on unit."
        },
        "unit": {
          "$ref": "#/$defs/action_unit"
        },
        "order_type": {
          "type": "string",
          "enum": [
            "market",
            "limit",
            "close",
            "open",
            "rebalance"
          ]
        },
        "limit_price": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_trade_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string"
        },
        "priority_override": {
          "$ref": "#/$defs/priority",
          "description": "Optional priority assigned to this specific action."
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "target_type": {
          "type": "string",
          "enum": [
            "symbol",
            "basket",
            "asset_class",
            "sector",
            "theme",
            "factor",
            "portfolio",
            "cash",
            "custom"
          ],
          "description": "Disambiguates the target namespace. Use basket for candidate_baskets, portfolio for whole-portfolio actions, cash for cash actions, and symbol for individual securities."
        },
        "from": {
          "type": "string",
          "description": "Source basket, symbol, asset class, sector, theme, or portfolio bucket for rotate actions."
        },
        "to": {
          "type": "string",
          "description": "Destination basket, symbol, asset class, sector, theme, or portfolio bucket for rotate actions."
        },
        "from_type": {
          "type": "string",
          "enum": [
            "symbol",
            "basket",
            "asset_class",
            "sector",
            "theme",
            "factor",
            "portfolio",
            "cash",
            "custom"
          ],
          "description": "Namespace for the rotate source target."
        },
        "to_type": {
          "type": "string",
          "enum": [
            "symbol",
            "basket",
            "asset_class",
            "sector",
            "theme",
            "factor",
            "portfolio",
            "cash",
            "custom"
          ],
          "description": "Namespace for the rotate destination target."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "increase_weight",
                  "decrease_weight",
                  "set_weight",
                  "buy",
                  "sell",
                  "hold",
                  "rebalance",
                  "raise_cash",
                  "reduce_risk",
                  "block_trade",
                  "allow_trade",
                  "set_regime_bias",
                  "emit_signal",
                  "custom"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "target"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "increase_weight",
                  "decrease_weight",
                  "set_weight",
                  "buy",
                  "sell",
                  "raise_cash",
                  "reduce_risk",
                  "allocate_to_basket",
                  "reduce_basket",
                  "replace_low_ranked",
                  "rotate"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "amount"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "rotate"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "from",
              "to",
              "amount"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "allocate_to_basket",
                  "reduce_basket",
                  "rank_and_select",
                  "replace_low_ranked"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "target",
              "target_type"
            ]
          }
        }
      ]
    },
    "action_type": {
      "type": "string",
      "enum": [
        "increase_weight",
        "decrease_weight",
        "set_weight",
        "buy",
        "sell",
        "hold",
        "rebalance",
        "raise_cash",
        "reduce_risk",
        "block_trade",
        "allow_trade",
        "rotate",
        "allocate_to_basket",
        "reduce_basket",
        "rank_and_select",
        "replace_low_ranked",
        "set_regime_bias",
        "emit_signal",
        "custom"
      ]
    },
    "action_unit": {
      "type": "string",
      "enum": [
        "weight",
        "shares",
        "dollars",
        "percent",
        "basis_points",
        "risk_fraction",
        "score",
        "custom"
      ],
      "default": "weight"
    },
    "cooldown": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional rule cooldown to prevent repeated firing.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "days": {
          "type": "integer",
          "minimum": 0
        },
        "scope": {
          "type": "string",
          "enum": [
            "rule",
            "target",
            "portfolio"
          ],
          "default": "rule"
        }
      }
    },
    "rule_limits": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional limits applied to this rule's requested actions.",
      "properties": {
        "max_fire_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_fire_count_per_year": {
          "type": "integer",
          "minimum": 0
        },
        "max_total_weight_change": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_single_action_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "requires_portfolio_approval": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional human-readable explanation metadata used for decision traces.",
      "properties": {
        "summary": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "expected_behavior": {
          "type": "string"
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "type": "string"
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "expires_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "category_key": {
          "type": "string"
        },
        "supersedes_policy": {
          "type": "string",
          "enum": [
            "latest_effective_date_wins",
            "none"
          ]
        },
        "source_report_ref": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "signal_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "series_id": {
          "type": "string"
        },
        "adapter": {
          "type": "string"
        },
        "dataset": {
          "type": "string"
        }
      }
    },
    "transform_spec": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "window": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "data_requirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "frequency": {
          "type": "string"
        },
        "lookback": {
          "type": "string"
        },
        "price_adjustment": {
          "type": "string"
        },
        "requires_ohlcv": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string"
        },
        "rating": {
          "type": "string"
        },
        "direction": {
          "type": "string"
        },
        "entry_price": {
          "type": "number"
        },
        "target_price": {
          "type": "number"
        },
        "stop_loss": {
          "type": "number"
        },
        "time_horizon": {
          "type": "string"
        },
        "horizon_days": {
          "type": "integer"
        },
        "position_sizing": {
          "type": "string"
        },
        "allocation_pct": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "signal_interest_condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "right": {
          "type": "string"
        },
        "value": {},
        "unit": {
          "type": "string"
        }
      }
    },
    "signal_interest_threshold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "value": {},
        "unit": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        }
      }
    },
    "signal_interest_interpretation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interpretation_id": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/signal_interest_condition"
        },
        "meaning": {
          "type": "string"
        },
        "recommendation_bias": {
          "type": "string"
        },
        "action_bias": {
          "type": "string"
        },
        "applies_to": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_text": {
          "type": "string"
        },
        "thresholds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal_interest_threshold"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "signal_interest_resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        },
        "data_provider": {
          "type": "string"
        },
        "backtester_supported": {
          "type": "boolean"
        },
        "requires_ohlcv": {
          "type": "boolean"
        },
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "agent_report_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "format",
        "path"
      ],
      "properties": {
        "engine": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "format": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "family"
      ],
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "signal_kind": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/signal_source"
            }
          ]
        },
        "instrument": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "transform": {
          "type": "string"
        },
        "transform_spec": {
          "$ref": "#/$defs/transform_spec"
        },
        "window": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "value": {},
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "recommendation": {
          "$ref": "#/$defs/recommendation"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "data_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_requirement"
          }
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_price": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "value_range": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "signal_interest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "family"
      ],
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/signal_source"
            }
          ]
        },
        "instrument": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "transform": {
          "type": "string"
        },
        "transform_spec": {
          "$ref": "#/$defs/transform_spec"
        },
        "window": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "data_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_requirement"
          }
        },
        "required_fields": {
          "type": "array",
